{
  "name": "speakup",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI Copilot for on-chain shareholder governance. Give every on-chain shareholder a voice.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run --filter '*' test",
    "lint": "bun run --filter '*' lint",
    "typecheck": "bun run --filter '*' typecheck",
    "dev": "bun run --filter './packages/app' dev",
    "agent": "bun run --filter './packages/agent' start",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,sol}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prettier-plugin-solidity": "^1.4.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.3.0",
    "node": ">=20"
  }
}
